<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Bugtoe – Book Page</title>

<style>
  body {
    margin: 0;
    padding: 0;
    background: #333;
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: center;
    padding: 40px 0;
  }

  /* BACK BUTTON */
  .back-button {
    position: fixed;
    top: 20px;
    left: 20px;
    font-size: 40px;
    font-weight: bold;
    color: white;
    text-decoration: none;
    z-index: 9999;
    opacity: 0.8;
    transition: 0.2s;
  }
  .back-button:hover { opacity: 1; }

  /* BOOK PAGE WRAPPER */
  .book-page {
    width: 800px;
    background: #fdf7e3; /* parchment tone */
    padding: 60px 80px;
    box-shadow: 0 0 25px rgba(0,0,0,0.6);
    border: 2px solid #d8c9a3;
    position: relative;
  }

  /* Decorative inner shadow */
  .book-page::after {
    content: "";
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 40px rgba(0,0,0,0.25);
    pointer-events: none;
  }

  /* BOOK HEADER */
  .chapter-title {
    font-family: "Papyrus", fantasy;
    font-size: 40px;
    text-align: center;
    margin-bottom: 20px;
  }

  /* BOOK CONTENT */
  .section-title {
    font-size: 28px;
    margin: 25px 0 10px;
    font-weight: bold;
  }

  .info-line {
    font-size: 20px;
    margin: 6px 0;
  }

  /* PAGE NUMBER */
  .page-number {
    text-align: center;
    margin-top: 40px;
    font-size: 18px;
    opacity: 0.6;
  }

  /* SIDE BANNERS */
  .side-banner {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.25;
  }
  .side-banner.left { left: -120px; }
  .side-banner.right { right: -120px; }
  .side-banner img { height: 350px; }

  /* MOBILE */
  @media (max-width: 900px) {
    body { padding: 20px 0; }

    .book-page {
      width: 90vw;
      padding: 30px;
    }

    .side-banner { display: none; }

    .back-button {
      font-size: 32px;
      top: 10px;
      left: 10px;
    }
  }
</style>
</head>

<body>

<a href="index.html" class="back-button">← Home</a>

<div class="book-page">

  <!-- SIDE BANNERS -->
  <div class="side-banner left">
    <img src="key.png" alt="Key Banner">
  </div>
  <div class="side-banner right">
    <img src="key.png" alt="Key Banner">
  </div>

  <!-- BOOK CONTENT -->
  <div class="chapter-title">About the Author</div>

  <div class="section-title">Profile</div>
  <div class="info-line">Name: Danny</div>
  <div class="info-line">Nationality: United Kingdom</div>
  <div class="info-line">Favorite Color: Pink</div>
  <div class="info-line">Favorite Food: Lasagna</div>
  <div class="info-line">Age: 15</div>

  <div class="section-title">Links / Socials</div>
  <div class="info-line">Roblox: @W0CET</div>
  <div class="info-line">Discord: W0CET</div>
  <div class="info-line">
    <a href="https://www.youtube.com/@NuhCracker" style="color:black; font-weight:bold;">
      YouTube Account
    </a>
  </div>

  <div class="page-number">Page 1</div>

</div>

</body>
</html>
